<Window x:Class="PasswordAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Analyzer"
        Height="450"
        Width="700">

    <Grid Margin="24">
        <StackPanel>

            <TextBlock Text="Password Analyzer"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <PasswordBox x:Name="PasswordInput"
                         Height="35"
                         PasswordChanged="PasswordInput_PasswordChanged"
                         Margin="0,0,0,15"/>

            <Button Content="Analyze"
                    Height="35"
                    Click="Analyze_Click"
                    Margin="0,0,0,20"/>

            <TextBlock Text="{Binding StrengthLabel}"
                       FontSize="20"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding EntropyText}"
                       FontSize="16"
                       Margin="0,10,0,0"/>

            <TextBlock Text="{Binding WarningText}"
                       FontSize="16"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"/>

        </StackPanel>
    </Grid>
</Window>