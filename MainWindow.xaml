<Window x:Class="PasswordAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Analyzer"
        Height="300"
        Width="400">
<Grid Margin="20">

    <StackPanel>

        <!-- Instruction text -->
        <TextBlock Text="Please enter password:"
                   FontSize="18"
                   Margin="0,0,0,10"/>

        <!-- Password input -->
        <TextBox Height="30"
                 FontSize="16"
                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Strength bar -->
<ProgressBar Height="20"
             Margin="0,15,0,0"
             Minimum="0"
             Maximum="100"
             Value="{Binding Score}"
             Foreground="{Binding BarColor}" />
        <!-- Strength label -->
        <TextBlock FontSize="18"
                   Margin="0,10,0,0"
                   Text="{Binding Strength}" />

         <TextBlock Text="{Binding Warning}"
           Foreground="Red"
           FontSize="14"
           TextWrapping="Wrap"
           Margin="0,10,0,0"/>          

    </StackPanel>

</Grid>
</Window>